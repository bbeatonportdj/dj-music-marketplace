# Supabase (for OAuth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server JWT secret (min 32 chars, set in Vercel too)
JWT_SECRET=replace_with_strong_secret

# Supabase service role key (get from Supabase dashboard > Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=replace_with_real_service_role_key

# Comma-separated admin emails (first user becomes admin if DB empty)
ADMIN_EMAILS=admin@beatvault.dj,bbeatonportdj@gmail.com

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: Slipok or other payment keys
SLIPOK_KEY=your_slipok_key

# Notes:
# - In Supabase dashboard, enable Google and Facebook providers under Auth > Providers.
# - Add redirect URLs:
#   - http://localhost:5173/auth?oauth=1&provider=google
#   - http://localhost:5173/auth?oauth=1&provider=facebook
# - For production, replace localhost with your domain.
