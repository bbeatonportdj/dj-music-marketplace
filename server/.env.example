# Database (Supabase PostgreSQL)
# Get from: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Security
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
WEBHOOK_SECRET=your-webhook-secret

# Payment - Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Payment - PromptPay
PROMPTPAY_ID=0812345678
SLIPOK_API_KEY=your-slipok-api-key (optional)

# Frontend URL (for Stripe redirects)
FRONTEND_URL=https://your-netlify-site.netlify.app

# Payment Simulation (dev only)
ALLOW_PAYMENT_SIMULATION=true

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="DJ Music Marketplace <noreply@yourdomain.com>"
ADMIN_ALERT_EMAIL=admin@yourdomain.com

# CORS
ALLOWED_ORIGINS=https://your-netlify-site.netlify.app,http://localhost:5173

# Server
PORT=5001
NODE_ENV=production